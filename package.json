{
  "name": "@sirv/react",
  "version": "0.1.0",
  "description": "React components for displaying Sirv assets: responsive images, videos, 360 spins, Sirv views, and combined media-viewer galleries.",
  "keywords": ["sirv", "react", "image", "cdn", "responsive", "srcset", "video", "360", "spin", "gallery"],
  "homepage": "https://github.com/sirv/sirv-react#readme",
  "repository": { "type": "git", "url": "https://github.com/sirv/sirv-react.git" },
  "bugs": { "url": "https://github.com/sirv/sirv-react/issues" },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./next": {
      "import": { "types": "./dist/next.d.ts", "default": "./dist/next.js" },
      "require": { "types": "./dist/next.d.cts", "default": "./dist/next.cjs" }
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "node scripts/build-docs.mjs",
    "lint": "biome check ."
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^24.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^1.6.1"
  },
  "publishConfig": { "access": "public" }
}
